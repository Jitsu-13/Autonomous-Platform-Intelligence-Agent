# LLM Provider: set to "openai" or "anthropic"
# If not set, auto-detects based on which key is present
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Linear
LINEAR_API_KEY=lin_api_...

# Optional: restrict to a specific Linear team key (e.g. BACK) or team UUID
LINEAR_TEAM_ID=

# SQLite memory database path (default: ./memory.db)
MEMORY_DB_PATH=./memory.db
